/
  Cache-Control: no-cache, no-store, must-revalidate

/index.html
  Cache-Control: no-cache, no-store, must-revalidate

/sw.js
  Cache-Control: no-cache, no-store, must-revalidate
  Service-Worker-Allowed: /

/app.js
  Cache-Control: no-cache, no-store, must-revalidate

/styles.css
  Cache-Control: no-cache, no-store, must-revalidate

/manifest.webmanifest
  Cache-Control: no-cache

/assets/index-*
  Cache-Control: public, max-age=31536000, immutable

/assets/icon.svg
  Cache-Control: public, max-age=604800

/assets/wordcloud-*
  Cache-Control: no-cache, no-store, must-revalidate
